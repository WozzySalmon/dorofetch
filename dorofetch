# Colors
R='\033[0m'
P='\033[38;5;213m'   # pink
M='\033[38;5;177m'   # magenta
W='\033[38;5;255m'   # white
C='\033[38;5;51m'    # cyan
Y='\033[38;5;228m'   # yellow
G='\033[38;5;114m'   # green
B='\033[1m'          # bold

# в”Җв”Җ System Info в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

get_os() {
    if [[ -f /etc/os-release ]]; then
        . /etc/os-release; echo "${PRETTY_NAME:-$NAME}"
    elif [[ "$(uname)" == "Darwin" ]]; then
        echo "macOS $(sw_vers -productVersion 2>/dev/null)"
    else uname -o 2>/dev/null || uname -s; fi
}

get_kernel() { uname -r; }

get_host() {
    if [[ -f /sys/devices/virtual/dmi/id/product_name ]]; then
        cat /sys/devices/virtual/dmi/id/product_name 2>/dev/null
    elif [[ "$(uname)" == "Darwin" ]]; then
        sysctl -n hw.model 2>/dev/null
    else echo "Unknown"; fi
}

get_uptime() { uptime -p 2>/dev/null || uptime | sed 's/.*up/up/'; }
get_shell() { basename "${SHELL:-unknown}"; }

get_cpu() {
    if [[ -f /proc/cpuinfo ]]; then
        grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | xargs
    elif [[ "$(uname)" == "Darwin" ]]; then
        sysctl -n machdep.cpu.brand_string 2>/dev/null
    else echo "Unknown"; fi
}

get_memory() {
    if [[ -f /proc/meminfo ]]; then
        awk '/MemTotal/ {t=$2} /MemAvailable/ {a=$2} END {print int((t-a)/1024) "MiB / " int(t/1024) "MiB"}' /proc/meminfo
    elif [[ "$(uname)" == "Darwin" ]]; then
        echo "$(($(sysctl -n hw.memsize) / 1048576))MiB"
    fi
}

get_gpu() {
    if command -v lspci &>/dev/null; then
        lspci 2>/dev/null | grep -i 'vga\|3d\|display' | head -1 | sed 's/.*: //'
    elif [[ "$(uname)" == "Darwin" ]]; then
        system_profiler SPDisplaysDataType 2>/dev/null | grep "Chipset Model" | sed 's/.*: //'
    else echo "Unknown"; fi
}

get_packages() {
    local count=0
    command -v dpkg-query &>/dev/null && count=$((count + $(dpkg-query -f '.\n' -W 2>/dev/null | wc -l)))
    command -v rpm &>/dev/null && count=$((count + $(rpm -qa 2>/dev/null | wc -l)))
    command -v pacman &>/dev/null && count=$((count + $(pacman -Qq 2>/dev/null | wc -l)))
    command -v brew &>/dev/null && count=$((count + $(brew list 2>/dev/null | wc -l)))
    [[ $count -gt 0 ]] && echo "$count" || echo "Unknown"
}

get_terminal() { echo "${TERM_PROGRAM:-${TERM:-unknown}}"; }

get_wm() { echo "${XDG_CURRENT_DESKTOP:-${DESKTOP_SESSION:-unknown}}"; }

# в”Җв”Җ Doro ASCII Art в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

ART_LINES=(
    "в Җв Җв Җв ҖвўҖв ҙвЈІвЈҜвЈүвЈҪвЈҝвЎӣв »вЈ¶в –вў’вў¶вЈҰвЈ„в Җв Җв Җв Җв Җ"
    "в Җв ҖвўҖвЎҙвўҒвЎңв үв Ӣв үв №в үв ұвЎ„в ҷвўҰвЈјвЈҫвЈҝвЈҝвЈ§в Җв Җв Җв Җ"
    "в ҖвўҖвЎһвўҖвЎһвўҖвЎ„в Җв ҖвўҖвўёв Җв №вЎҖв ҲвЈҹв ҝвЈҝвЈҝвЈҹвЈүвЎҮв Җв Җ"
    "вЈҙвЈ«в Җвўёвў вЈҫвЎҮвў в Җвўёвў°вўҶв ҖвЎҮв Җвў№вЈҝвЈҝвЈҝвЈҝвЈҢвЎҮв Җв Җ"
    "в Җв ҖвўҖвЎјвў»в ӣвўҝвЎҫв ҰвЈҝвЈҝвЈҝвЈ·вЎҮв Җвўёв ҒвЈҜвЈҝв ӣвЎ№в ӣвЈҰв Җ"
    "в Җвў°вўЁв Җв Ҳвў“вўәвўҒвЈҖв ҖвўҝвўҖвЈјв ғв ҖвЈёвЈ в ғвЈҮвЎҙв Ғв ҖвўёвЎҮ"
    "в Җв ҳвЈҺвў“вўӨвЈ„вЈҖвЈүвЎүвЈҒвЈҖвЈ вЈҝвЎҶвў в ҹв Ғв Җв ҳв Ғв Җв ҖвўёвЎҮ"
    "в Җв Җв ҲвўәвЎҝв ҮвЎҖв үв үв үв үвўүвЈјвЎЎв Ӣв Җв ҖвўҖвЈҙв Җв ҖвЈ в ҹв Җ"
    "в Җв Җв Җв Җвў·вЎҖвў»вЎ¶вЈӨвЈӨв Җв Җв Җв ҖвЈҖвЈӨвЎҙв ӣвЎҮв Җв ҖвЎҸв Җв Җ"
    "в Җв Җв Җв Җв Ҳв ів јв ғв Җв Ҳвў§вЎҖв Җв ҖвЎҮв Җв Җв Җв »вЈ„вЈҖвЎҹв Җв Җ"
    "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв ҷв ¶в ҫв Ғв Җв Җв Җв Җв Ҳв үв Җв Җв Җ"
)

# в”Җв”Җ Info Lines в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

USER_HOST="${P}${B}${USER}${R}${W}@${P}${B}$(hostname)${R}"
SEP="${M}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${R}"

INFO_LINES=(
    "$USER_HOST"
    "$SEP"
    "${P}${B} OS${R}       ${W}$(get_os)${R}"
    "${P}${B} Host${R}     ${W}$(get_host)${R}"
    "${P}${B} Kernel${R}   ${W}$(get_kernel)${R}"
    "${P}${B} Uptime${R}   ${W}$(get_uptime)${R}"
    "${P}${B} Pkgs${R}     ${W}$(get_packages)${R}"
    "${P}${B} Shell${R}    ${W}$(get_shell)${R}"
    "${P}${B} Term${R}     ${W}$(get_terminal)${R}"
    "${P}${B} WM${R}       ${W}$(get_wm)${R}"
    "${P}${B} CPU${R}      ${W}$(get_cpu)${R}"
    "${P}${B} GPU${R}      ${W}$(get_gpu)${R}"
    "${P}${B} Memory${R}   ${W}$(get_memory)${R}"
    "$SEP"
    "${M}  в—Ҹ${P}  в—Ҹ${C}  в—Ҹ${G}  в—Ҹ${Y}  в—Ҹ${W}  в—Ҹ${R}"
)

# в”Җв”Җ Render в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
BLANK_ART="в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ"

art_count=${#ART_LINES[@]}
info_count=${#INFO_LINES[@]}
max=$((art_count > info_count ? art_count : info_count))

echo ""
for ((i = 0; i < max; i++)); do
    if ((i < art_count)); then
        art="${ART_LINES[$i]}"
    elif ((i == art_count)); then
        art="     d o r o f e t c h   "
    else
        art=""
    fi
    
    info="${INFO_LINES[$i]:-}"
    
    if [[ -n "$art" ]]; then
        echo -e "  ${P}${art}${R}  ${info}"
    else
        # 52 spaces = 2 prefix + 48 art width + 2 suffix
        echo "                                                    ${info}"
    fi
done
echo ""
