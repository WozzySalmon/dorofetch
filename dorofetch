#!/usr/bin/env bash
#  ____                   _____    _       _
# |  _ \  ___  _ __ ___  |  ___|__| |_ ___| |__
# | | | |/ _ \| '__/ _ \ | |_ / _ \ __/ __| '_ \
# | |_| | (_) | | | (_) ||  _|  __/ || (__| | | |
# |____/ \___/|_|  \___/ |_|  \___|\__\___|_| |_|
#
# dorofetch - a neofetch clone that prints Doro
# by Mr.Bigg & Jess

# ── Default Colors ───────────────────────────────────────────────────────

R='\033[0m'
P='\033[38;5;213m'   # pink
M='\033[38;5;177m'   # magenta
W='\033[38;5;255m'   # white
C='\033[38;5;51m'    # cyan
Y='\033[38;5;228m'   # yellow
G='\033[38;5;114m'   # green
B='\033[1m'          # bold

# ── Logo Loading ─────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LOGO_DIR="${SCRIPT_DIR}/logos"

find_logo() {
    local name="$1"

    # If it's a direct file path that exists, use it as-is
    if [[ -f "$name" ]]; then
        echo "$name"
        return
    fi

    # Check logos/ directory for image files first, then .txt
    for ext in png jpg jpeg gif webp txt; do
        if [[ -f "${LOGO_DIR}/${name}.${ext}" ]]; then
            echo "${LOGO_DIR}/${name}.${ext}"
            return
        fi
    done

    # Default to logos/doro.txt if nothing found
    echo "${LOGO_DIR}/doro.txt"
}

# Allow --logo <name> flag
while [[ $# -gt 0 ]]; do
    case "$1" in
        --logo|-l)
            LOGO_FILE=$(find_logo "$2")
            shift 2
            ;;
        *) shift ;;
    esac
done

# Default if not set by argument
[[ -z "$LOGO_FILE" ]] && LOGO_FILE=$(find_logo "doro")

load_image_logo() {
    local file="$1"
    ART_LINES=()

    if ! command -v chafa &>/dev/null; then
        echo -e "${Y}Warning: chafa not found. Falling back to text logo.${R}"
        local base_name
        base_name=$(basename "${file%.*}")
        load_logo "${LOGO_DIR}/${base_name}.txt"
        return
    fi

    while IFS= read -r line; do
        ART_LINES+=("$line")
    done < <(chafa --size x30 --symbols braille --color-space din99d "$file")

    LOGO_COLOR="" # Chafa output has its own ANSI codes
}

load_logo() {
    local file="$1"
    local logo_colors=()
    ART_LINES=()

    while IFS= read -r line; do
        # Parse color header: "# colors: 213 177 51"
        if [[ "$line" =~ ^#\ colors:\ (.+) ]]; then
            read -ra logo_colors <<< "${BASH_REMATCH[1]}"
            continue
        fi
        # Skip other comments and empty lines at top
        [[ "$line" =~ ^# ]] && continue
        [[ -z "$line" ]] && continue

        # Replace $1, $2, $3... with ANSI color codes from header
        for i in "${!logo_colors[@]}"; do
            local n=$((i + 1))
            local color_code
            color_code=$(printf '\033[38;5;%sm' "${logo_colors[$i]}")
            line="${line//\$$n/$color_code}"
        done

        ART_LINES+=("$line")
    done < "$file"

    # If no color header found, use default pink
    if [[ ${#logo_colors[@]} -eq 0 ]]; then
        LOGO_COLOR="$P"
    else
        LOGO_COLOR="\033[38;5;${logo_colors[0]}m"
    fi
}

if [[ "$LOGO_FILE" =~ \.(png|jpg|jpeg|gif|webp)$ ]]; then
    load_image_logo "$LOGO_FILE"
else
    load_logo "$LOGO_FILE"
fi

# ── System Info ──────────────────────────────────────────────────────────

get_os() {
    if [[ -f /etc/os-release ]]; then
        . /etc/os-release; echo "${PRETTY_NAME:-$NAME}"
    elif [[ "$(uname)" == "Darwin" ]]; then
        echo "macOS $(sw_vers -productVersion 2>/dev/null)"
    else uname -o 2>/dev/null || uname -s; fi
}

get_kernel() { uname -r; }

get_host() {
    if [[ -f /sys/devices/virtual/dmi/id/product_name ]]; then
        cat /sys/devices/virtual/dmi/id/product_name 2>/dev/null
    elif [[ "$(uname)" == "Darwin" ]]; then
        sysctl -n hw.model 2>/dev/null
    else echo "Unknown"; fi
}

get_uptime() { uptime -p 2>/dev/null || uptime | sed 's/.*up/up/'; }
get_shell() { basename "${SHELL:-unknown}"; }

get_cpu() {
    if [[ -f /proc/cpuinfo ]]; then
        grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | xargs
    elif [[ "$(uname)" == "Darwin" ]]; then
        sysctl -n machdep.cpu.brand_string 2>/dev/null
    else echo "Unknown"; fi
}

get_memory() {
    if [[ -f /proc/meminfo ]]; then
        awk '/MemTotal/ {t=$2} /MemAvailable/ {a=$2} END {print int((t-a)/1024) "MiB / " int(t/1024) "MiB"}' /proc/meminfo
    elif [[ "$(uname)" == "Darwin" ]]; then
        echo "$(($(sysctl -n hw.memsize) / 1048576))MiB"
    fi
}

get_gpu() {
    if command -v lspci &>/dev/null; then
        lspci 2>/dev/null | grep -i 'vga\|3d\|display' | head -1 | sed 's/.*: //'
    elif [[ "$(uname)" == "Darwin" ]]; then
        system_profiler SPDisplaysDataType 2>/dev/null | grep "Chipset Model" | sed 's/.*: //'
    else echo "Unknown"; fi
}

get_packages() {
    local count=0
    command -v dpkg-query &>/dev/null && count=$((count + $(dpkg-query -f '.\n' -W 2>/dev/null | wc -l)))
    command -v rpm &>/dev/null && count=$((count + $(rpm -qa 2>/dev/null | wc -l)))
    command -v pacman &>/dev/null && count=$((count + $(pacman -Qq 2>/dev/null | wc -l)))
    command -v brew &>/dev/null && count=$((count + $(brew list 2>/dev/null | wc -l)))
    [[ $count -gt 0 ]] && echo "$count" || echo "Unknown"
}

get_terminal() { echo "${TERM_PROGRAM:-${TERM:-unknown}}"; }

get_wm() { echo "${XDG_CURRENT_DESKTOP:-${DESKTOP_SESSION:-unknown}}"; }

# ── Info Lines ───────────────────────────────────────────────────────────

USER_HOST="${P}${B}${USER}${R}${W}@${P}${B}$(hostname)${R}"
SEP="${M}──────────────────────────────${R}"

INFO_LINES=(
    "$USER_HOST"
    "$SEP"
    "${P}${B} OS${R}       ${W}$(get_os)${R}"
    "${P}${B} Host${R}     ${W}$(get_host)${R}"
    "${P}${B} Kernel${R}   ${W}$(get_kernel)${R}"
    "${P}${B} Uptime${R}   ${W}$(get_uptime)${R}"
    "${P}${B} Pkgs${R}     ${W}$(get_packages)${R}"
    "${P}${B} Shell${R}    ${W}$(get_shell)${R}"
    "${P}${B} Term${R}     ${W}$(get_terminal)${R}"
    "${P}${B} WM${R}       ${W}$(get_wm)${R}"
    "${P}${B} CPU${R}      ${W}$(get_cpu)${R}"
    "${P}${B} GPU${R}      ${W}$(get_gpu)${R}"
    "${P}${B} Memory${R}   ${W}$(get_memory)${R}"
    "$SEP"
    "${M}  ●${P}  ●${C}  ●${G}  ●${Y}  ●${W}  ●${R}"
)

# ── Render ───────────────────────────────────────────────────────────────

art_count=${#ART_LINES[@]}
info_count=${#INFO_LINES[@]}
INFO_START=52

echo ""
for ((i = 0; i < art_count; i++)); do
    printf "  ${LOGO_COLOR}%s${R}\033[${INFO_START}G" "${ART_LINES[$i]}"
    echo -e "${INFO_LINES[$i]:-}"
done

# "dorofetch" label + next info line
printf "  ${LOGO_COLOR}     d o r o f e t c h${R}\033[${INFO_START}G"
echo -e "${INFO_LINES[$art_count]:-}"

# remaining info lines
for ((i = art_count + 1; i < info_count; i++)); do
    printf "\033[${INFO_START}G"
    echo -e "${INFO_LINES[$i]}"
done
echo ""
